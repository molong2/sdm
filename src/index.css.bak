/* ============================================================
   초자연재난관리국 업무망 — 전역 스타일
   한국 정부 인트라넷 (라이트 테마)
   ============================================================ */

:root {
  /* ── 배경 계층 ───────────────────────────────────────────── */
  --bg-page:       #edf1f7;  /* 페이지 바탕 (연한 청회색) */
  --bg-nav:        #0c2d5e;  /* 헤더 (짙은 남색) */
  --bg-sidebar:    #f4f6fb;  /* 사이드바 */
  --bg-sidebar-hd: #e4eaf4;  /* 사이드바 그룹 헤더 */
  --bg-box:        #ffffff;  /* 콘텐츠 카드 */
  --bg-th:         #dce8f6;  /* 테이블 헤더 행 */
  --bg-stripe:     #f0f5fb;  /* 테이블 짝수행 */
  --bg-hover:      #d4e4f8;  /* 호버 */
  --bg-sel:        #bed6f8;  /* 선택 행 */
  --bg-sechd:      #e8f0fa;  /* 섹션 제목 바 */
  --bg-breadcrumb: #dce6f2;  /* 빵부스러기 바 */
  --bg-status:     #d4dff0;  /* 하단 상태 바 */

  /* ── 테두리 ─────────────────────────────────────────────── */
  --border:        #b8cce0;
  --border-dim:    #d8e6f0;
  --border-active: #1460c8;

  /* ── 텍스트 (본문용) ─────────────────────────────────────── */
  --text-1: #1a2d42;   /* 주요 */
  --text-2: #3a5878;   /* 보조 */
  --text-3: #7090b0;   /* 흐림 */

  /* ── 강조색 ─────────────────────────────────────────────── */
  --blue:   #1460c8;
  --blue-l: #2878e8;
  --green:  #0e7840;
  --red:    #b82030;
  --yellow: #8e6008;
  --purple: #5e38a8;
  --gray:   #506878;

  /* ── 레이아웃 ───────────────────────────────────────────── */
  --header-h:  52px;
  --sidebar-w: 200px;
  --status-h:  22px;

  /* ── 서체 ───────────────────────────────────────────────── */
  --font: '맑은 고딕', 'Malgun Gothic', 'Apple SD Gothic Neo',
          'Noto Sans KR', -apple-system, sans-serif;
  --mono: 'Consolas', 'Courier New', monospace;

  --r: 1px;    /* 거의 직각 — 정부 시스템 스타일 */
  --t: 100ms ease;
}

/* ── 리셋 ──────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }

body {
  background: var(--bg-page);
  color: var(--text-1);
  font-family: var(--font);
  font-size: 12px;
  line-height: 1.4;
}

#root { height: 100%; display: flex; flex-direction: column; }

/* 스크롤바 */
::-webkit-scrollbar             { width: 6px; height: 6px; }
::-webkit-scrollbar-track       { background: #e0eaf4; }
::-webkit-scrollbar-thumb       { background: #b0c4da; border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: #8aacc8; }

/* ============================================================
   앱 그리드
   ============================================================ */

.app {
  display: grid;
  grid-template-rows: var(--header-h) 1fr var(--status-h);
  grid-template-columns: var(--sidebar-w) 1fr;
  height: 100%;
  overflow: hidden;
}

/* ============================================================
   헤더 (짙은 남색 — 항상 어두운 배경)
   ============================================================ */

.header {
  grid-column: 1 / -1;
  background: var(--bg-nav);
  border-bottom: 3px solid #1870e0;
  display: flex;
  align-items: stretch;
  user-select: none;
}

.header__org {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 18px;
  flex: 1;
  border-right: 1px solid rgba(255,255,255,.12);
}

.header__emblem {
  width: 34px; height: 34px;
  border: 1.5px solid rgba(130,180,255,.5);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #90c0ff;
  font-size: 15px;
  flex-shrink: 0;
}

.header__name-ko {
  font-size: 15px; font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.5px;
  line-height: 1.2;
}

.header__name-en {
  font-size: 9px;
  color: rgba(255,255,255,.45);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-top: 2px;
}

.header__userbox {
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 10px;
  flex-shrink: 0;
}

.header__userinfo {
  display: flex;
  align-items: stretch;
  border: 1px solid rgba(255,255,255,.2);
  border-radius: var(--r);
  overflow: hidden;
  font-size: 11px;
}

.header__uinfo-cell {
  padding: 4px 11px;
  border-right: 1px solid rgba(255,255,255,.12);
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.header__uinfo-cell:last-child { border-right: none; }

.header__uinfo-label {
  font-size: 9px;
  color: rgba(255,255,255,.42);
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.header__uinfo-value {
  font-size: 11px;
  color: #ffffff;
  font-weight: 700;
}

.header__day-cell {
  background: rgba(0,0,0,.2);
  padding: 4px 14px;
}

.header__day-val {
  font-family: var(--mono);
  font-size: 13px;
  color: #90c8ff;
  font-weight: 700;
}

/* ============================================================
   사이드바
   ============================================================ */

.sidebar {
  background: var(--bg-sidebar);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  overflow: hidden;
}

.sidebar__scroll { flex: 1; overflow-y: auto; }

.sidebar__grp-hd {
  background: var(--bg-sidebar-hd);
  border-top: 1px solid var(--border-dim);
  border-bottom: 1px solid var(--border-dim);
  padding: 5px 12px;
  font-size: 10px;
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 1px;
  user-select: none;
}

.sidebar__grp-hd:first-child { border-top: none; }

.sidebar__item {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 14px;
  color: var(--text-2);
  cursor: pointer;
  border-left: 3px solid transparent;
  border-bottom: 1px solid var(--border-dim);
  transition: background var(--t), color var(--t);
  user-select: none;
  font-size: 12px;
}

.sidebar__item:hover {
  background: var(--bg-hover);
  color: var(--blue);
}

.sidebar__item--active {
  background: #e0ecff;
  border-left-color: var(--blue);
  color: var(--blue);
  font-weight: 700;
}

.sidebar__item-icon {
  width: 14px; text-align: center;
  flex-shrink: 0; font-size: 11px;
  color: var(--text-3);
}

.sidebar__item--active .sidebar__item-icon { color: var(--blue); }
.sidebar__item-label { flex: 1; }

.sidebar__badge {
  background: var(--red); color: #fff;
  font-size: 9px; font-weight: 700;
  padding: 0 5px; line-height: 16px;
  border-radius: 1px; min-width: 16px; text-align: center;
}

/* ============================================================
   빵부스러기 경로
   ============================================================ */

.breadcrumb {
  background: var(--bg-breadcrumb);
  border-bottom: 1px solid var(--border);
  padding: 0 14px;
  display: flex; align-items: center; gap: 4px;
  height: 26px;
  flex-shrink: 0;
  font-size: 11px;
  color: var(--text-3);
  user-select: none;
}

.breadcrumb__sep { color: var(--text-3); margin: 0 2px; }
.breadcrumb__cur { color: var(--blue); font-weight: 700; }

/* ============================================================
   콘텐츠 영역
   ============================================================ */

.content {
  overflow: hidden;
  display: flex; flex-direction: column;
  background: var(--bg-page);
  padding: 10px;
}

/* 패널 카드 */
.panel {
  flex: 1;
  border: 1px solid var(--border);
  background: var(--bg-box);
  display: flex; flex-direction: column;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(20,60,120,.06);
}

/* ── 섹션 제목 바 ─────────────────────────────────────────── */

.sec-hd {
  background: var(--bg-sechd);
  border-bottom: 1px solid var(--border);
  border-left: 3px solid var(--blue);
  padding: 7px 14px;
  display: flex; align-items: center; gap: 8px;
  flex-shrink: 0;
  user-select: none;
}

.sec-hd__mark  { color: var(--blue); font-size: 11px; }
.sec-hd__title { font-size: 13px; font-weight: 700; color: var(--text-1); flex: 1; }
.sec-hd__info  { font-size: 11px; color: var(--text-3); }
.sec-hd__info--alert { color: var(--red); font-weight: 700; }

/* ── 돌아가기 버튼 ────────────────────────────────────────── */

.back-bar {
  background: var(--bg-sechd);
  border-bottom: 1px solid var(--border);
  padding: 5px 12px;
  flex-shrink: 0;
}

.back-btn {
  background: #ffffff;
  border: 1px solid var(--border);
  color: var(--text-2);
  padding: 3px 10px;
  font-size: 11px; font-family: var(--font);
  cursor: pointer; border-radius: var(--r);
  transition: background var(--t), color var(--t), border-color var(--t);
}

.back-btn:hover {
  background: var(--bg-hover);
  border-color: var(--blue);
  color: var(--blue);
}

/* ============================================================
   데이터 테이블
   ============================================================ */

.tbl-wrap { overflow-y: auto; overflow-x: hidden; flex: 1; }

.tbl {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
  table-layout: fixed;
}

.tbl thead th {
  background: var(--bg-th);
  color: var(--text-2);
  font-weight: 700;
  padding: 6px 8px;
  border: 1px solid var(--border);
  border-top: none;
  border-bottom: 2px solid var(--blue);
  text-align: center;
  white-space: nowrap;
  font-size: 11px;
  position: sticky; top: 0; z-index: 1;
}

.tbl thead th:first-child { border-left: none; }
.tbl thead th:last-child  { border-right: none; }

.tbl tbody td {
  padding: 5px 8px;
  border-bottom: 1px solid var(--border-dim);
  border-right: 1px solid var(--border-dim);
  color: var(--text-1);
  overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
  vertical-align: middle;
}

.tbl tbody td:last-child { border-right: none; }

.tbl tbody tr:nth-child(even) td { background: var(--bg-stripe); }

.tbl tbody tr:hover td {
  background: var(--bg-hover);
  cursor: pointer;
}

.tbl tbody tr.tbl-row--sel td {
  background: var(--bg-sel);
}

.tbl tbody tr.tbl-row--unread td { font-weight: 700; }

/* 열 스타일 */
.tbl-col-num  { width: 42px !important; text-align: center !important; color: var(--text-3) !important; font-family: var(--mono); font-size: 11px !important; }
.tbl-col-dot  { width: 24px !important; text-align: center !important; }
.tbl-col-date { width: 82px !important; text-align: center !important; font-family: var(--mono); font-size: 11px !important; color: var(--text-3) !important; }
.tbl-col-stat { width: 70px !important; text-align: center !important; }
.tbl-col-dept { width: 110px !important; color: var(--text-2) !important; }
.tbl-col-from { width: 90px !important; color: var(--text-2) !important; }
.tbl-col-cat  { width: 72px !important; text-align: center !important; color: var(--text-2) !important; }
.tbl-col-class { width: 72px !important; text-align: center !important; }

/* 미읽음 점 */
.unread-dot {
  display: inline-block;
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--blue);
  vertical-align: middle;
}

/* 잠긴 행 */
.tbl-row--locked { opacity: 0.45; cursor: default !important; }
.tbl-row--locked:hover td { background: inherit !important; cursor: default !important; }

/* ============================================================
   배지 / 상태 태그
   ============================================================ */

.badge {
  display: inline-block;
  padding: 1px 6px;
  font-size: 10px; font-weight: 700;
  border-radius: var(--r);
  white-space: nowrap;
  border: 1px solid;
}

/* 사건 상태 */
.badge--open       { background: #d8f0e4; color: #0a5e30; border-color: #80c898; }
.badge--pending    { background: #faecd0; color: #7a4808; border-color: #d4a060; }
.badge--closed     { background: #e4eaf4; color: #3a5878; border-color: #98b4d0; }
.badge--classified { background: #ecdcf8; color: #500080; border-color: #b880e0; }
.badge--archived   { background: #e0eaf2; color: #406080; border-color: #90b0c8; }

/* 직원 상태 */
.badge--active    { background: #d8f0e4; color: #0a5e30; border-color: #80c898; }
.badge--inactive  { background: #e4eaf4; color: #3a5878; border-color: #98b4d0; }
.badge--on_leave  { background: #faecd0; color: #7a4808; border-color: #d4a060; }
.badge--suspended { background: #f8dce0; color: #900020; border-color: #d07888; }
.badge--unknown   { background: #e0eaf2; color: #406080; border-color: #90b0c8; }

/* 문서 보안등급 */
.badge--public       { background: #d4f0e8; color: #0a5230; border-color: #70c098; }
.badge--internal     { background: #d4e8ff; color: #0a3a78; border-color: #70a0e0; }
.badge--confidential { background: #faecd0; color: #6a3808; border-color: #c09040; }
.badge--secret       { background: #ecdcf8; color: #500080; border-color: #b880e0; }

/* 기타 */
.badge--system   { background: #dceeff; color: #0040a0; border-color: #80b0e8; }
.badge--urgent   { background: #f8dce0; color: #900020; border-color: #d07888; }
.badge--normal   { background: #e8eef6; color: #406080; border-color: #98b4cc; }
.badge--info     { background: #dceeff; color: #0040a0; border-color: #80b0e8; }
.badge--warning  { background: #faecd0; color: #7a4808; border-color: #d4a060; }
.badge--meeting  { background: #d8f0e4; color: #0a5e30; border-color: #80c898; }
.badge--deadline { background: #f8dce0; color: #900020; border-color: #d07888; }
.badge--reminder { background: #e8eef6; color: #406080; border-color: #98b4cc; }
.badge--event    { background: #ecdcf8; color: #500080; border-color: #b880e0; }

/* ============================================================
   홈 패널
   ============================================================ */

.home-body {
  overflow-y: auto;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* 홈 위젯 */
.hw { border: 1px solid var(--border); background: var(--bg-box); }

.hw__hd {
  background: var(--bg-th);
  border-bottom: 2px solid var(--blue);
  padding: 5px 12px;
  display: flex; align-items: center; gap: 8px;
}

.hw__hd-mark  { color: var(--blue); font-size: 10px; }
.hw__hd-title { font-size: 12px; font-weight: 700; color: var(--text-1); flex: 1; }
.hw__hd-cnt   { font-size: 11px; color: var(--text-3); }

/* 공지 행 */
.notice-row {
  display: flex; align-items: center;
  border-bottom: 1px solid var(--border-dim);
}

.notice-row:last-child { border-bottom: none; }

.notice-row__num {
  width: 40px; text-align: center; flex-shrink: 0;
  font-family: var(--mono); font-size: 11px; color: var(--text-3);
  padding: 6px 4px;
  border-right: 1px solid var(--border-dim);
}

.notice-row__badge {
  padding: 6px 8px; flex-shrink: 0;
  border-right: 1px solid var(--border-dim);
  width: 52px; text-align: center;
}

.notice-row__title {
  flex: 1; padding: 6px 10px;
  font-size: 12px; color: var(--text-1);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  border-right: 1px solid var(--border-dim);
  cursor: pointer;
}

.notice-row__title:hover { color: var(--blue); text-decoration: underline; }

.notice-row__author {
  width: 72px; padding: 6px 8px;
  font-size: 11px; color: var(--text-3); text-align: center;
  border-right: 1px solid var(--border-dim);
  flex-shrink: 0;
}

.notice-row__date {
  width: 66px; padding: 6px 8px;
  font-family: var(--mono); font-size: 11px; color: var(--text-3);
  text-align: center; flex-shrink: 0;
}

/* 일정 행 */
.sched-row {
  display: flex; align-items: center;
  border-bottom: 1px solid var(--border-dim);
}

.sched-row:last-child { border-bottom: none; }

.sched-row__time {
  width: 60px; flex-shrink: 0;
  font-family: var(--mono); font-size: 12px; color: var(--blue);
  text-align: center; padding: 7px 8px;
  border-right: 1px solid var(--border-dim);
  font-weight: 700;
}

.sched-row__type {
  width: 56px; flex-shrink: 0;
  padding: 7px 8px; text-align: center;
  border-right: 1px solid var(--border-dim);
}

.sched-row__content { flex: 1; padding: 7px 10px; }
.sched-row__title   { font-size: 12px; color: var(--text-1); }
.sched-row__desc    { font-size: 11px; color: var(--text-3); margin-top: 2px; }

/* 알림 행 */
.alert-row {
  display: flex; align-items: center;
  border-bottom: 1px solid var(--border-dim);
  padding: 6px 10px;
  gap: 8px;
}

.alert-row:last-child { border-bottom: none; }

.alert-row__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--blue); flex-shrink: 0; }
.alert-row__dot--warning { background: var(--yellow); }
.alert-row__dot--system  { background: var(--gray); }

.alert-row__time {
  font-family: var(--mono); font-size: 11px; color: var(--text-3);
  width: 50px; flex-shrink: 0;
}

.alert-row__msg { font-size: 12px; color: var(--text-1); flex: 1; }

.home-empty {
  padding: 16px; text-align: center;
  font-size: 12px; color: var(--text-3);
}

/* ============================================================
   상세 뷰 공통
   ============================================================ */

.detail-body {
  padding: 18px 20px;
  overflow-y: auto;
  flex: 1;
}

.det-subtitle {
  font-family: var(--mono); font-size: 11px;
  color: var(--text-3); margin-bottom: 6px;
}

.det-title {
  font-size: 16px; font-weight: 700;
  color: var(--text-1); margin-bottom: 14px;
  line-height: 1.4;
}

.det-meta {
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: 5px 10px;
  margin-bottom: 14px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--border-dim);
}

.det-meta__lbl { font-size: 11px; color: var(--text-3); padding-top: 1px; }
.det-meta__val { font-size: 12px; color: var(--text-2); }

.det-section-title {
  font-size: 10px; color: var(--text-3);
  text-transform: uppercase; letter-spacing: 0.8px;
  margin: 16px 0 6px;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--border-dim);
}

.det-content {
  font-size: 12px; color: var(--text-1);
  line-height: 1.8; white-space: pre-wrap; word-break: break-word;
}

.det-notes {
  background: var(--bg-stripe);
  border: 1px solid var(--border-dim);
  padding: 10px 12px;
  font-size: 12px; color: var(--text-2);
  line-height: 1.6; white-space: pre-wrap;
}

/* 빈 화면 */
.panel-empty {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  height: 100%; gap: 8px;
  color: var(--text-3); text-align: center;
}

.panel-empty__ico  { font-size: 28px; opacity: 0.2; }
.panel-empty__text { font-size: 12px; }

/* ============================================================
   폐기 자료 특수
   ============================================================ */

.disc-lock-view {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 40px 20px; gap: 12px; text-align: center;
}

.disc-lock-view__ico  { font-size: 32px; color: var(--text-3); opacity: 0.3; }
.disc-lock-view__msg  { font-size: 13px; color: var(--text-3); }
.disc-lock-view__cond { font-size: 11px; color: var(--text-3); opacity: 0.7; font-family: var(--mono); }

.redacted {
  background: var(--text-3);
  color: transparent;
  border-radius: 1px;
  user-select: none;
  font-family: var(--mono);
  opacity: 0.5;
}

/* ============================================================
   문서 태그
   ============================================================ */

.doc-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 14px; }
.doc-tag {
  font-size: 10px; color: var(--text-3);
  border: 1px solid var(--border-dim); padding: 1px 6px;
  background: var(--bg-stripe);
}

/* ============================================================
   설정 패널
   ============================================================ */

.settings-body { overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 12px; }

.settings-block { border: 1px solid var(--border); }

.settings-block__hd {
  background: var(--bg-th);
  border-bottom: 2px solid var(--blue);
  padding: 5px 12px;
  font-size: 11px; font-weight: 700; color: var(--text-2);
  text-transform: uppercase; letter-spacing: 0.8px;
}

.settings-row {
  display: flex; align-items: center;
  padding: 7px 12px;
  border-bottom: 1px solid var(--border-dim);
}

.settings-row:last-child { border-bottom: none; }
.settings-row:nth-child(even) { background: var(--bg-stripe); }

.settings-row__lbl  { flex: 1; font-size: 12px; color: var(--text-1); }
.settings-row__desc { font-size: 10px; color: var(--text-3); margin-top: 1px; }
.settings-row__val  { font-family: var(--mono); font-size: 12px; color: var(--blue); font-weight: 700; }

.settings-note {
  padding: 8px 12px;
  background: #fdf8e8;
  border: 1px solid #e0d090;
  font-size: 11px; color: #604808; line-height: 1.5;
  margin-top: 6px;
}

.danger-btn {
  border: 1px solid #d07888;
  background: #fff0f2;
  color: var(--red);
  padding: 4px 12px;
  font-size: 12px; font-family: var(--font);
  cursor: pointer; border-radius: var(--r);
  transition: background var(--t);
}

.danger-btn:hover { background: #ffe0e4; }

/* ============================================================
   관리자 패널
   ============================================================ */

.admin-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.35);
  z-index: 1000;
  display: flex; align-items: flex-start; justify-content: flex-end;
  padding: 58px 14px 14px;
}

.admin-panel {
  background: #ffffff;
  border: 1px solid var(--border);
  box-shadow: 0 4px 20px rgba(0,0,0,.2);
  width: 300px; max-height: 80vh;
  display: flex; flex-direction: column;
  overflow: hidden;
}

.admin-panel__hd {
  background: #fff0f2;
  border-bottom: 2px solid var(--red);
  padding: 8px 12px;
  display: flex; align-items: center; justify-content: space-between;
}

.admin-panel__title { font-size: 11px; font-weight: 700; color: var(--red); text-transform: uppercase; letter-spacing: 1px; }

.admin-panel__close {
  background: none; border: none; color: var(--text-3);
  cursor: pointer; font-size: 14px; padding: 2px 6px;
  transition: color var(--t);
}

.admin-panel__close:hover { color: var(--text-1); }

.admin-panel__body {
  overflow-y: auto; padding: 12px;
  display: flex; flex-direction: column; gap: 14px;
}

.admin-sec__title {
  font-size: 10px; color: var(--text-3);
  text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;
  padding-bottom: 4px; border-bottom: 1px solid var(--border-dim);
}

.admin-day { display: flex; align-items: center; gap: 10px; }
.admin-day__val { font-family: var(--mono); font-size: 18px; font-weight: 700; color: var(--blue); min-width: 44px; text-align: center; }

.admin-btn {
  background: #f4f6fb; border: 1px solid var(--border);
  color: var(--text-2); padding: 4px 10px; font-size: 12px;
  font-family: var(--font); cursor: pointer; border-radius: var(--r);
  transition: background var(--t);
}

.admin-btn:hover { background: var(--bg-hover); }
.admin-btn:disabled { opacity: 0.4; cursor: default; }
.admin-btn--danger { border-color: #d07888; color: var(--red); background: #fff8f8; }
.admin-btn--danger:hover { background: #ffe8ea; }

.admin-flag-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 5px 0; border-bottom: 1px solid var(--border-dim);
}

.admin-flag-row:last-child { border-bottom: none; }
.admin-flag-name { font-family: var(--mono); font-size: 11px; color: var(--text-2); }

/* 토글 */
.toggle { position: relative; display: inline-block; width: 34px; height: 18px; cursor: pointer; }
.toggle input { opacity: 0; width: 0; height: 0; }
.toggle__track { position: absolute; inset: 0; background: #c8d8e8; border-radius: 9px; transition: background var(--t); }
.toggle input:checked + .toggle__track { background: var(--green); }
.toggle__thumb { position: absolute; top: 2px; left: 2px; width: 14px; height: 14px; background: #ffffff; border-radius: 50%; transition: transform var(--t); pointer-events: none; box-shadow: 0 1px 3px rgba(0,0,0,.25); }
.toggle input:checked ~ .toggle__thumb { transform: translateX(16px); }

.admin-warn { font-size: 10px; color: var(--text-3); text-align: center; padding: 8px 0 2px; border-top: 1px solid var(--border-dim); line-height: 1.5; }

/* ============================================================
   하단 상태 바
   ============================================================ */

.statusbar {
  grid-column: 1 / -1;
  background: var(--bg-status);
  border-top: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 0 12px;
  font-size: 10px;
  color: var(--text-3);
  user-select: none;
}

.statusbar__cell {
  padding: 0 10px;
  border-right: 1px solid var(--border-dim);
  white-space: nowrap;
  display: flex; align-items: center; gap: 4px;
}

.statusbar__cell:first-child { padding-left: 0; }
.statusbar__cell:last-child  { border-right: none; }

.statusbar__dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--green); display: inline-block;
}

.statusbar__spacer { flex: 1; }

/* ============================================================
   반응형
   ============================================================ */

@media (max-width: 900px) {
  :root { --sidebar-w: 175px; }
}

@media (max-width: 640px) {
  :root { --sidebar-w: 0px; }
  .sidebar { display: none; }
  .app { grid-template-columns: 1fr; }
}
